# Single-VM deploy (Docker Compose / same host as backend): leave the Vercel vars
# unset and the app talks to the backend on its own origin.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_COLLAB_WS_URL=ws://localhost:1234

# ── Vercel (split deploy: UI on Vercel, backend + WebSockets on the VM) ────────
# Set these in the Vercel project's Environment Variables. REST is proxied by the
# next.config rewrite; WebSockets (terminal, collab) go straight to the VM because
# Vercel cannot proxy long-lived WebSocket connections.
#   BACKEND_URL=https://<vm-host>          # e.g. https://34-14-181-224.sslip.io
#   NEXT_PUBLIC_WS_HOST=wss://<vm-host>    # same host, wss:// scheme
