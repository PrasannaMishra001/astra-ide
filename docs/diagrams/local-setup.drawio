<mxfile host="app.diagrams.net" type="device">
  <diagram name="Local Setup" id="astra-local">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="ASTRA-IDE — Local Setup (docker compose up)" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="16" width="440" height="28" as="geometry" />
        </mxCell>

        <mxCell id="cmd" value="cd deploy&#10;docker compose up --build" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#333333;fontColor=#ffffff;fontFamily=monospace;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="net" value="Docker network — services reach each other by name" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#999999;fontSize=11;fontStyle=2;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="880" height="470" as="geometry" />
        </mxCell>

        <mxCell id="frontend" value="frontend (Next.js)&#10;port 3000&#10;open http://localhost:3000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="backend" value="backend (FastAPI)&#10;port 8000&#10;docs at /api/v1/docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="200" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="collab" value="collab (y-websocket)&#10;port 1234&#10;/healthz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="200" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="pg" value="postgres&#10;port 5432" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="330" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="redis" value="redis&#10;port 6379" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="330" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="minio" value="minio (S3)&#10;port 9000 · console 9001" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="330" width="190" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dsock" value="/var/run/docker.sock (mounted into backend)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="450" width="290" height="50" as="geometry" />
        </mxCell>
        <mxCell id="wsc" value="per-workspace containers&#10;docker run (runc / gVisor) · docker exec for the terminal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="390" y="530" width="290" height="60" as="geometry" />
        </mxCell>

        <mxCell id="user" value="Developer" style="shape=umlActor;verticalLabelPosition=bottom;verticalAlign=top;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="640" width="40" height="70" as="geometry" />
        </mxCell>

        <mxCell id="ce1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" edge="1" parent="1" source="cmd" target="net"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce2" value="proxy /api" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;dashed=1;" edge="1" parent="1" source="frontend" target="backend"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" edge="1" parent="1" source="backend" target="pg"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" edge="1" parent="1" source="backend" target="redis"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" edge="1" parent="1" source="backend" target="minio"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" edge="1" parent="1" source="backend" target="dsock"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;" edge="1" parent="1" source="dsock" target="wsc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce8" value="localhost:3000" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;fontSize=10;" edge="1" parent="1" source="user" target="frontend"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
